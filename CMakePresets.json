{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 24,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "dev",
      "displayName": "Development",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/dev",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "BUILD_TESTING": "ON",
        "SSTV_BUILD_GUI": "ON"
      }
    },
    {
      "name": "headless",
      "displayName": "Headless development",
      "inherits": "dev",
      "binaryDir": "${sourceDir}/build/headless",
      "cacheVariables": {
        "SSTV_BUILD_GUI": "OFF"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "dev",
      "configurePreset": "dev"
    },
    {
      "name": "headless",
      "configurePreset": "headless"
    }
  ],
  "testPresets": [
    {
      "name": "dev",
      "configurePreset": "dev",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "headless",
      "configurePreset": "headless",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}

