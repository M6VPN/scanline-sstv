{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 24,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "dev",
      "displayName": "Development",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/dev",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "BUILD_TESTING": "ON",
        "SSTV_BUILD_GUI": "ON",
        "SSTV_ENABLE_LIVE_TX": "OFF",
        "SSTV_ENABLE_TX_HARDWARE_TESTS": "OFF",
        "SSTV_ARM_TX_HARDWARE_TESTS": "OFF"
      }
    },
    {
      "name": "headless",
      "displayName": "Headless development",
      "inherits": "dev",
      "binaryDir": "${sourceDir}/build/headless",
      "cacheVariables": {
        "SSTV_BUILD_GUI": "OFF"
      }
    },
    {
      "name": "live-tx-compile",
      "displayName": "Live TX compiled with hardware tests disabled",
      "inherits": "headless",
      "binaryDir": "${sourceDir}/build/live-tx-compile",
      "cacheVariables": {
        "SSTV_ENABLE_LIVE_TX": "ON",
        "SSTV_ENABLE_TX_HARDWARE_TESTS": "OFF",
        "SSTV_ARM_TX_HARDWARE_TESTS": "OFF"
      }
    },
    {
      "name": "live-tx-gui-compile",
      "displayName": "Live TX GUI compiled with hardware tests disabled",
      "inherits": "dev",
      "binaryDir": "${sourceDir}/build/live-tx-gui-compile",
      "cacheVariables": {
        "SSTV_ENABLE_LIVE_TX": "ON",
        "SSTV_ENABLE_TX_HARDWARE_TESTS": "OFF",
        "SSTV_ARM_TX_HARDWARE_TESTS": "OFF"
      }
    },
    {
      "name": "minimal",
      "displayName": "Minimal core-only development",
      "inherits": "headless",
      "binaryDir": "${sourceDir}/build/minimal",
      "cacheVariables": {
        "SSTV_BUILD_IMAGE": "OFF",
        "SSTV_BUILD_AUDIO": "OFF"
      }
    },
    {
      "name": "audio-disabled",
      "displayName": "Headless image build without audio discovery",
      "inherits": "headless",
      "binaryDir": "${sourceDir}/build/audio-disabled",
      "cacheVariables": {
        "SSTV_BUILD_AUDIO": "OFF"
      }
    },
    {
      "name": "asan",
      "displayName": "Clang AddressSanitizer",
      "inherits": "headless",
      "binaryDir": "${sourceDir}/build/asan",
      "cacheVariables": {
        "CMAKE_CXX_COMPILER": "clang++",
        "CMAKE_CXX_FLAGS": "-fsanitize=address -fno-omit-frame-pointer"
      }
    },
    {
      "name": "ubsan",
      "displayName": "Clang UndefinedBehaviorSanitizer",
      "inherits": "headless",
      "binaryDir": "${sourceDir}/build/ubsan",
      "cacheVariables": {
        "CMAKE_CXX_COMPILER": "clang++",
        "CMAKE_CXX_FLAGS": "-fsanitize=undefined -fno-sanitize-recover=all -fno-omit-frame-pointer"
      }
    },
    {
      "name": "tsan",
      "displayName": "Clang ThreadSanitizer audio concurrency",
      "inherits": "headless",
      "binaryDir": "${sourceDir}/build/tsan",
      "cacheVariables": {
        "CMAKE_CXX_COMPILER": "clang++",
        "CMAKE_CXX_FLAGS": "-fsanitize=thread -fno-omit-frame-pointer"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "dev",
      "configurePreset": "dev"
    },
    {
      "name": "headless",
      "configurePreset": "headless"
    },
    {
      "name": "live-tx-compile",
      "configurePreset": "live-tx-compile"
    },
    {
      "name": "live-tx-gui-compile",
      "configurePreset": "live-tx-gui-compile"
    },
    {
      "name": "minimal",
      "configurePreset": "minimal"
    },
    {
      "name": "audio-disabled",
      "configurePreset": "audio-disabled"
    },
    {
      "name": "asan",
      "configurePreset": "asan"
    },
    {
      "name": "ubsan",
      "configurePreset": "ubsan"
    },
    {
      "name": "tsan",
      "configurePreset": "tsan"
    }
  ],
  "testPresets": [
    {
      "name": "dev",
      "configurePreset": "dev",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "headless",
      "configurePreset": "headless",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "live-tx-compile",
      "configurePreset": "live-tx-compile",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "live-tx-gui-compile",
      "configurePreset": "live-tx-gui-compile",
      "environment": {
        "QT_QPA_PLATFORM": "offscreen",
        "QT_QUICK_BACKEND": "software"
      },
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "minimal",
      "configurePreset": "minimal",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "audio-disabled",
      "configurePreset": "audio-disabled",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "asan",
      "configurePreset": "asan",
      "environment": {
        "ASAN_OPTIONS": "detect_leaks=1:halt_on_error=1"
      },
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "ubsan",
      "configurePreset": "ubsan",
      "environment": {
        "UBSAN_OPTIONS": "halt_on_error=1:print_stacktrace=1"
      },
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "tsan",
      "configurePreset": "tsan",
      "filter": {
        "include": {
          "label": "audio-concurrency"
        }
      },
      "environment": {
        "TSAN_OPTIONS": "halt_on_error=1"
      },
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
